{
  "name": "createrington-skin-api",
  "version": "2.6.0",
  "license": "Apache-2.0",
  "description": "Official TypeScript client for the Createrington Skin API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/matejhozlar/skin-api-ts"
  },
  "homepage": "https://api.createrington.com",
  "scripts": {
    "build": "tsc && tsc-alias",
    "generate:poses": "tsx scripts/generate-poses.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "clean": "rimraf dist",
    "prepack": "npm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,css,md}": "prettier --write"
  }
}
